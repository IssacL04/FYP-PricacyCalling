APP_HOST=0.0.0.0
APP_PORT=8080
API_KEY=my-strong-api-key-001
DB_PATH=/home/ubuntu/fyp/PrivacyCalling/data/privacy.db

CALL_TIMEOUT_SEC_DEFAULT=30
CALL_TIMEOUT_SEC_MAX=120

ASTERISK_DIAL_CONTEXT=privacy_bridge
ASTERISK_DIAL_EXTEN=s
ASTERISK_DIAL_PRIORITY=1

ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=privacyapi
ASTERISK_AMI_SECRET=change-this-secret
ASTERISK_AMI_RECONNECT_MS=5000
ASTERISK_AMI_CONNECT_TIMEOUT_MS=8000

AUTH_MODE=api_key
AUTH_ENABLE_API_KEY_FALLBACK=true
AUTH_JWT_SECRET=my-demo-jwt-secret-2026
AUTH_JWT_EXPIRES_SEC=300
AUTH_CHALLENGE_TTL_SEC=60
AUTH_DEMO_MODE=true
AUTH_DEMO_ADDRESS=0x1111111111111111111111111111111111111111
AUTH_DEMO_NODE_ID=demo-node

