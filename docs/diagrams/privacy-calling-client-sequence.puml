@startuml
skinparam shadowing false
skinparam defaultFontName "Noto Sans CJK SC"
autonumber

actor "SIP 主叫客户端\n(例如 alice)" as Caller
participant "Asterisk Dialplan\n[caller_in]" as DP
participant "Asterisk Dialplan\n[resolve_target/select_virtual]" as RES
participant "Asterisk Bridge" as BR
participant "AmiClient" as AMI
participant "CallStateMachine" as SM
database "SQLite" as DB
actor "SIP 被叫客户端\n(例如 bob)" as Callee

Caller -> DP : INVITE bob / +8613900000002
DP -> RES : Gosub resolve_target + select_virtual
RES --> DP : TARGET_ENDPOINT + VIRTUAL_ID
DP -> BR : Dial(PJSIP/${TARGET_ENDPOINT})\n并设置 CALLERID=${VIRTUAL_ID}
DP -> AMI : UserEvent PrivacyClientCallCreate
AMI -> SM : processEvent(PrivacyClientCallCreate)
SM -> DB : 若无记录则 createCallWithLegs

DP -> AMI : UserEvent PrivacyCallState(A,answered)
AMI -> SM : processEvent
SM -> DB : update A-leg / call status

BR -> Callee : B-leg ringing
DP -> AMI : UserEvent PrivacyCallState(B,dialing)
AMI -> SM : processEvent
SM -> DB : B-leg ringing

Callee --> BR : 接听
DP -> AMI : UserEvent PrivacyCallState(B,answered)
AMI -> SM : processEvent
SM -> DB : status=bridged

Caller -> BR : 挂断或被叫挂断
DP -> AMI : UserEvent PrivacyCallState(ALL,hangup)
AMI -> SM : processEvent
SM -> DB : status=completed 或 failed

@enduml
