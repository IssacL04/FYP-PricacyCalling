@startuml
skinparam shadowing false
skinparam defaultFontName "Noto Sans CJK SC"

node "Cloud VM / Linux 主机" {
  node "systemd" {
    artifact "asterisk.service"
    artifact "privacy-calling-api.service"
  }

  node "Asterisk" as ast {
    component "PJSIP(UDP:5160)"
    component "AMI(TCP:5038, localhost)"
    component "RTP(UDP:20000-20199)"
    artifact "extensions.conf"
    artifact "pjsip.conf"
  }

  node "Node.js API" as api {
    component "Express /v1/*"
    component "Dashboard /dashboard"
    component "CallStateMachine"
  }

  database "SQLite\nprivacy.db" as db
}

node "用户设备" {
  actor "SIP Client A"
  actor "SIP Client B"
}

cloud "运营商/外部 SIP Trunk\n(可选)" as trunk

"SIP Client A" --> ast : SIP
"SIP Client B" --> ast : SIP
api --> ast : AMI (127.0.0.1)
api --> db : local file I/O
ast --> trunk : trunk 呼叫

@enduml
