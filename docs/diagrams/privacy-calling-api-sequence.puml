@startuml
skinparam shadowing false
skinparam defaultFontName "Noto Sans CJK SC"
autonumber

actor "API 调用方" as Client
participant "Express API" as API
participant "CallService" as Svc
database "SQLite" as DB
participant "AmiClient" as AMI
participant "Asterisk" as AST
participant "CallStateMachine" as SM

Client -> API : POST /v1/calls\ncaller_user_id, callee_e164
API -> Svc : createCall(...)
Svc -> DB : getUserById / select virtual
Svc -> DB : createCallWithLegs(created)

alt AMI 已认证
  Svc -> DB : update status=originating
  Svc -> AMI : Originate(ActionID=orig-<callId>)
  AMI -> AST : AMI Action Originate
  AST --> AMI : Response Success
  Svc --> API : 201 {call_id, selected_virtual_id}
  API --> Client : 201 Created
else AMI 不可用
  Svc -> DB : mark failed(ami_not_connected)
  Svc --> API : throw 503
  API --> Client : 503 asterisk_unavailable
end

== 异步状态回写 ==
AST -> AMI : Event OriginateResponse / UserEvent / Hangup
AMI -> SM : processEvent(event)
SM -> DB : update calls + call_legs

Client -> API : GET /v1/calls/{id}
API -> Svc : getCall(id)
Svc -> DB : getCallWithLegs
Svc --> API : call status
API --> Client : 200 JSON

@enduml
