APP_HOST=0.0.0.0
APP_PORT=8080
API_KEY=change-me-api-key
DB_PATH=./data/privacy.db

AUTH_MODE=api_key
AUTH_ENABLE_API_KEY_FALLBACK=true
AUTH_JWT_SECRET=change-me-jwt-secret
AUTH_JWT_EXPIRES_SEC=300
AUTH_CHALLENGE_TTL_SEC=60
AUTH_DEMO_MODE=false
AUTH_DEMO_ADDRESS=0x1111111111111111111111111111111111111111
AUTH_DEMO_NODE_ID=demo-node

CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CHAIN_ALLOWLIST_CONTRACT=
CHAIN_ALLOWLIST_MODE=static
CHAIN_ALLOWED_ADDRESSES=

CALL_TIMEOUT_SEC_DEFAULT=30
CALL_TIMEOUT_SEC_MAX=120

ASTERISK_DIAL_CONTEXT=privacy_bridge
ASTERISK_DIAL_EXTEN=s
ASTERISK_DIAL_PRIORITY=1

ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=privacyapi
ASTERISK_AMI_SECRET=change-this-secret
ASTERISK_AMI_RECONNECT_MS=5000
ASTERISK_AMI_CONNECT_TIMEOUT_MS=8000

OPS_DASHBOARD_ENABLED=true
OPS_ALLOW_SERVICE_CONTROL=true
OPS_USE_SUDO_FOR_CONTROL=true
OPS_COMMAND_TIMEOUT_MS=8000
OPS_SYSTEMCTL_BIN=systemctl
OPS_SUDO_BIN=sudo
OPS_MANAGED_SERVICES=asterisk,privacy-calling-api
OPS_LOG_DEFAULT_LIMIT=200
OPS_LOG_MAX_LIMIT=500
OPS_LOG_DEFAULT_SINCE_SEC=600
OPS_JOURNALCTL_BIN=journalctl
OPS_LOG_TAIL_BIN=tail
OPS_LOG_USE_SUDO=false
OPS_LOG_INCLUDE_ASTERISK_FULL=true
OPS_LOG_ASTERISK_FULL_PATH=/var/log/asterisk/full
OPS_ALERT_LOAD_PER_CPU_WARN=0.8
OPS_ALERT_LOAD_PER_CPU_ERROR=1.2
OPS_ALERT_HEAP_USAGE_WARN=0.75
OPS_ALERT_HEAP_USAGE_ERROR=0.9
OPS_ALERT_ACTIVE_CALLS_WARN=30
OPS_ALERT_ACTIVE_CALLS_ERROR=50
